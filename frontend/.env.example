# Base URL for the EVAS API. Default uses the Vite dev proxy at /api -> :8000.
# In production set this to wherever FastAPI is served (e.g. https://evas.example.com).
VITE_EVAS_API_BASE=/api

# Dev-only: bootstrap token gating POST /auth/token (matches EVAS_BOOTSTRAP_TOKEN
# on the backend). Leave empty to use the in-app mock/login without a live token.
VITE_EVAS_BOOTSTRAP_TOKEN=
