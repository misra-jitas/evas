# EVAS configuration (12-factor). Copy to .env and fill in.
# All variables are prefixed EVAS_.

# --- Database ---
EVAS_DATABASE_URL=postgresql+psycopg2://evas:evas@localhost:5432/evas

# --- S3 / object storage ---
EVAS_S3_BUCKET_VIDEOS=evas-videos
EVAS_S3_BUCKET_FRAMES=evas-frames
EVAS_S3_REGION=us-east-1
# For MinIO/LocalStack set an endpoint; leave unset for real AWS.
# EVAS_S3_ENDPOINT_URL=http://localhost:9000
# EVAS_AWS_ACCESS_KEY_ID=...
# EVAS_AWS_SECRET_ACCESS_KEY=...

# --- Anthropic ---
EVAS_ANTHROPIC_API_KEY=sk-ant-...
EVAS_AI_MODEL=claude-haiku-4-5
EVAS_AI_MAX_TOKENS=1024
EVAS_CONFIDENCE_FLAG_THRESHOLD=0.75

# --- Worker ---
EVAS_WORKER_POLL_INTERVAL_SECONDS=2.0
EVAS_WORKER_BATCH_SIZE=1

# --- Local scratch + export ---
EVAS_WORK_DIR=/tmp/evas
EVAS_EXPORT_DIR=exports
